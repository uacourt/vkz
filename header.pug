                path(d="M11 9C8 12 5 16 5 21v7c0 4 3 7 7 8V18")
                path(d="M19 9c3 3 6 7 6 12v7c0 4-3 7-7 8V18")
                path(d="M9 30h12")
            .header__titles
                h1.header__title!= headerTitle
                h4.header__subtitle!= headerSubtitle

        block content

